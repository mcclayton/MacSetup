"Vim commands must be uppercase, so these abbreviations make lowercase aliases work.
cnoreabbrev <expr> help getcmdtype() ==# ':' && getcmdline() ==# 'help' ? 'Hotkeys' : 'help'
cnoreabbrev <expr> hotkey getcmdtype() ==# ':' && getcmdline() ==# 'hotkey' ? 'Hotkeys' : 'hotkey'
cnoreabbrev <expr> hotkeys getcmdtype() ==# ':' && getcmdline() ==# 'hotkeys' ? 'Hotkeys' : 'hotkeys'

"Leader+? to show custom and plugin hotkeys
nnoremap <silent> <Leader>? :Hotkeys<CR>

"Use native current-file search with vim-anzu counts and is.vim highlight cleanup
nmap <silent> n <Plug>(is-nohl)<Plug>(anzu-n-with-echo)
nmap <silent> N <Plug>(is-nohl)<Plug>(anzu-N-with-echo)
nmap <silent> * <Plug>(anzu-star-with-echo)<Plug>(is-nohl-1)
nmap <silent> # <Plug>(anzu-sharp-with-echo)<Plug>(is-nohl-1)

augroup cadence_current_file_search
  autocmd!
  autocmd CmdlineLeave [/\?] if exists(':AnzuUpdateSearchStatusOutput') == 2 | AnzuUpdateSearchStatusOutput | endif
augroup END

"Ctrl+d to close side panels and enter a more minimal mode
nnoremap <silent> <C-d> :CloseSidePanels<CR>

"Ctrl+m to toggle code minimap
nnoremap <silent> <C-m> :ToggleCodeMinimap<CR>

"Ctrl+l to toggle GitGutter and GitLens
nnoremap <silent> <C-l> :ToggleGitTools<CR>

"Ctrl+n to toggle nerdtree
nnoremap <silent> <C-n> :ToggleExplorer<CR>

"Map Ctrl+t to open fzf for searching file names with a content preview
map <C-T> :call FzfWithPreview()<CR>

"Map Ctrl+Shift+f to open fzf + ripgrep for searching file contents globally
nnoremap <silent> <C-S-F> :FZFRgPrompt<CR>

"Map Ctrl+g to open fzf + ripgrep for searching file contents globally
nnoremap <silent> <C-g> :FZFRgPrompt<CR>

"Map Ctrl+f to native current-file search so matches highlight while typing
nnoremap <C-f> /

"Map Tab to navigate to next tab (using buffet plugin)
noremap <Tab> :bn<CR>
"Map Shift+Tab to navigate to previous tab (using buffet plugin)
noremap <S-Tab> :bp<CR>
"Map \ + Tab to close current tab (using buffet plugin)
noremap <Leader><Tab> :Bw<CR>

"Note: Ctrl+ww to switch between windows (i.e. Nerdtree and file)"
