function! s:hotkeys_popup_filter(id, key) abort
  if a:key ==# 'q' || a:key ==# "\<Esc>" || a:key ==# "\<CR>"
    call popup_close(a:id)
    return 1
  endif
  if a:key ==# 'j' || a:key ==# "\<Down>"
    call win_execute(a:id, 'normal! j')
    return 1
  endif
  if a:key ==# 'k' || a:key ==# "\<Up>"
    call win_execute(a:id, 'normal! k')
    return 1
  endif
  if a:key ==# 'g'
    call win_execute(a:id, 'normal! gg')
    return 1
  endif
  if a:key ==# 'G'
    call win_execute(a:id, 'normal! G')
    return 1
  endif
  if a:key ==# "\<C-d>" || a:key ==# "\<PageDown>"
    call win_execute(a:id, "normal! \<C-d>")
    return 1
  endif
  if a:key ==# "\<C-u>" || a:key ==# "\<PageUp>"
    call win_execute(a:id, "normal! \<C-u>")
    return 1
  endif
  return 0
endfunction

