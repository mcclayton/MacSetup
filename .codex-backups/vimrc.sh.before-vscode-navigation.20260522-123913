function! s:fzf_atom_one_dark_colors() abort
  return [
  \ '--color', 'fg:#ABB2BF,bg:#282C34,hl:#61AFEF,fg+:#D7DAE0,bg+:#2C313A,hl+:#61AFEF,info:#636D83,prompt:#98C379,pointer:#528BFF,marker:#98C379,spinner:#E5C07B,header:#5C6370,border:#3A3F4B,preview-fg:#ABB2BF,preview-bg:#282C34,preview-border:#3A3F4B,label:#61AFEF,query:#D7DAE0,gutter:#282C34'
  \ ]
endfunction

function! s:fzf_bat_command() abort
  if executable('bat')
    return 'bat'
  endif
  if executable('batcat')
    return 'batcat'
  endif
  return ''
endfunction

function! s:fzf_file_preview_command(file_placeholder) abort
  let l:header = 'printf "\033[1;38;2;97;175;239m%s\033[0m\n\033[2;38;2;92;99;112m%s\033[0m\n\n" "$(basename "$file")" "$file"; '
  let l:bat = s:fzf_bat_command()
  if !empty(l:bat)
    return 'sh -c ''file="$1"; ' . l:header . 'exec ' . l:bat . ' --theme="OneHalfDark" --style=numbers --color=always -- "$file"'' _ ' . a:file_placeholder
  endif
  return 'sh -c ''file="$1"; ' . l:header . 'sed -n "1,200p" "$file"'' _ ' . a:file_placeholder
endfunction

function! s:fzf_result_preview_command(file_placeholder, line_placeholder) abort
  let l:bat = s:fzf_bat_command()
  if !empty(l:bat)
    return l:bat . ' --theme="OneHalfDark" --style=numbers --color=always --highlight-line ' . a:line_placeholder . ' ' . a:file_placeholder
  endif
  return 'sh -c ''line="$1"; file="$2"; start=$((line > 20 ? line - 20 : 1)); end=$((line + 80)); nl -ba "$file" | sed -n "${start},${end}p"'' _ ' . a:line_placeholder . ' ' . a:file_placeholder
endfunction

function! s:fzf_wrap_with_layout(...) abort
  let l:spec = copy(a:0 == 1 ? a:1 : a:2)
  if get(g:, 'cadence_has_popup_windows', 0)
    let l:spec.window = { 'width': 0.95, 'height': 0.85, 'border': 'sharp' }
  else
    let l:spec.down = '40%'
  endif

  if a:0 == 1
    return fzf#wrap(l:spec)
  endif
  if a:0 == 2
    return fzf#wrap(a:1, l:spec)
  endif
  return fzf#wrap(a:1, l:spec, a:3)
endfunction

function! s:fzf_file_options(state) abort
  let l:options = [
  \ '--ansi',
  \ '--cycle',
  \ '--highlight-line',
  \ '--border-label', ' Files ',
  \ '--border-label-pos', '3',
  \ '--preview-label', ' Preview ',
  \ '--preview-label-pos', '3',
  \ '--prompt', 'Files > ',
  \ '--pointer', '> ',
  \ '--marker', '+ ',
  \ '--info', 'inline-right',
  \ '--scroll-off', '3',
  \ '--delimiter', "\t",
  \ '--with-nth', '1',
  \ '--nth', '1,2',
  \ '--tabstop', '2',
  \ '--no-hscroll',
  \ '--preview', s:fzf_file_preview_command('{2}'),
  \ '--preview-window', 'right:55%,border-left,~3',
  \ '--bind', 'focus:transform-preview-label:sh -c ''printf " %s " "$1"'' _ {2}',
  \ '--bind', 'ctrl-o:transform:' . s:fzf_file_state_command(a:state, 'ctrl-o'),
  \ '--bind', 'ctrl-e:transform:' . s:fzf_file_state_command(a:state, 'ctrl-e'),
  \ '--bind', 'ctrl-r:transform:' . s:fzf_file_state_command(a:state, 'ctrl-r'),
  \ '--bind', 'enter:transform:' . s:fzf_file_state_command(a:state, 'enter'),
  \ '--bind', 'esc:transform:' . s:fzf_file_state_command(a:state, 'esc'),
  \ '--bind', 'shift-up:preview-page-up,shift-down:preview-page-down,ctrl-u:preview-page-up,ctrl-d:preview-page-down,ctrl-/:toggle-preview'
  \ ]

  call extend(l:options, ['--header', 'Smart path display, filename + path in preview | Ctrl-o include | Ctrl-e exclude | Ctrl-r reset filters', '--header-first'])
  call extend(l:options, s:fzf_atom_one_dark_colors())
  return l:options
endfunction

function! FzfWithPreview()
  let l:state = s:fzf_file_state('', '', '')

  call fzf#run(s:fzf_wrap_with_layout({
  \ 'source': s:fzf_file_state_command(l:state, 'files'),
  \ 'sink': function('s:fzf_file_accept'),
  \ 'options': s:fzf_file_options(l:state),
  \ 'dir': getcwd()
  \ }))
endfunction

function! s:fzf_file_state(query, include, exclude) abort
  let l:dir = tempname()
  call mkdir(l:dir, 'p')

  let l:state = {
  \ 'dir': l:dir,
  \ 'script': l:dir . '/fzf-file-state.sh',
  \ 'search': l:dir . '/search',
  \ 'include': l:dir . '/include',
  \ 'exclude': l:dir . '/exclude'
  \ }

  call writefile([a:query], l:state.search)
  call writefile([a:include], l:state.include)
  call writefile([a:exclude], l:state.exclude)
  call writefile(s:fzf_file_state_script(l:state), l:state.script)
  call setfperm(l:state.script, 'rwx------')

  return l:state
endfunction

function! s:fzf_file_state_command(state, action) abort
  return shellescape(a:state.script) . ' ' . shellescape(a:action)
endfunction

function! s:fzf_file_state_script(state) abort
  return [
  \ '#!/bin/sh',
  \ 'search_file=' . shellescape(a:state.search),
  \ 'include_file=' . shellescape(a:state.include),
  \ 'exclude_file=' . shellescape(a:state.exclude),
  \ 'script_file="$0"',
  \ '',
  \ 'read_file() {',
  \ '  [ -f "$1" ] && cat "$1"',
  \ '}',
  \ '',
  \ 'write_current_query() {',
  \ '  printf "%s" "$FZF_QUERY" > "$1"',
  \ '}',
  \ '',
  \ 'split_patterns() {',
  \ "  awk -v input=\"$1\" '",
  \ '  function trim(x) { sub(/^[[:space:]]+/, "", x); sub(/[[:space:]]+$/, "", x); return x }',
  \ '  BEGIN {',
  \ '    depth = 0; item = ""',
  \ '    for (i = 1; i <= length(input); i++) {',
  \ '      c = substr(input, i, 1)',
  \ '      if (c == "{") depth++',
  \ '      else if (c == "}" && depth > 0) depth--',
  \ '      if (c == "," && depth == 0) {',
  \ '        item = trim(item)',
  \ '        if (item != "") print item',
  \ '        item = ""',
  \ '      } else {',
  \ '        item = item c',
  \ '      }',
  \ '    }',
  \ '    item = trim(item)',
  \ '    if (item != "") print item',
  \ '  }',
  \ "  '",
  \ '}',
  \ '',
  \ 'normalize_glob() {',
  \ '  g="$1"',
  \ '  [ -n "$g" ] || return',
  \ '  case "$g" in',
  \ '    */) printf "%s\n" "${g}**"; return ;;',
  \ '  esac',
  \ '  if printf "%s" "$g" | grep -q ''[][?*{}]''; then',
  \ '    printf "%s\n" "$g"',
  \ '    return',
  \ '  fi',
  \ '  if [ -d "$g" ]; then',
  \ '    printf "%s\n" "$g/**"',
  \ '  else',
  \ '    printf "%s\n" "$g"',
  \ '  fi',
  \ '}',
  \ '',
  \ 'format_files() {',
  \ "  awk '",
  \ '  BEGIN { blue = "\033[38;5;75m"; fg = "\033[38;5;145m"; dim = "\033[38;5;99m"; reset = "\033[0m" }',
  \ '  {',
  \ '    path = $0',
  \ '    name = path',
  \ '    sub(/^.*\//, "", name)',
  \ '    icon = ""',
  \ '    if (path ~ /\.go$/) icon = ""',
  \ '    else if (path ~ /\.(ts|tsx)$/) icon = ""',
  \ '    else if (path ~ /\.(js|jsx)$/) icon = ""',
  \ '    else if (path ~ /\.py$/) icon = ""',
  \ '    else if (path ~ /\.(md|mdx)$/) icon = ""',
  \ '    else if (path ~ /\.(json|jsonnet)$/) icon = ""',
  \ '    else if (path ~ /\.(yaml|yml)$/) icon = ""',
  \ '    else if (path ~ /\.(proto|pb\.go)$/) icon = "󰈚"',
  \ '    else if (path ~ /\.sql$/) icon = ""',
  \ '    else if (path ~ /\.(sh|bash|zsh)$/) icon = ""',
  \ '    else if (path ~ /\.vim$/) icon = ""',
  \ '    else if (path ~ /\.lua$/) icon = ""',
  \ '    else if (path ~ /\.(css|scss|sass)$/) icon = ""',
  \ '    else if (path ~ /\.(html|htm)$/) icon = ""',
  \ '    else if (path ~ /\.(bazel|bzl)$/ || path ~ /(^|\/)BUILD(\.bazel)?$/ || path ~ /(^|\/)MODULE\.bazel$/) icon = ""',
  \ '    else if (path ~ /(^|\/)Dockerfile$/) icon = ""',
  \ '    else if (path ~ /(^|\/)Makefile$/) icon = ""',
  \ '    smart = path',
  \ '    src = index(smart, "/src/")',
  \ '    if (src > 0) smart = substr(smart, src + 1)',
  \ '    max = 76',
  \ '    if (length(smart) > max) {',
  \ '      root = smart',
  \ '      sub(/\/.*/, "", root)',
  \ '      middle = smart',
  \ '      sub(/^[^\/]*\//, "", middle)',
  \ '      sub(/\/[^\/]*$/, "", middle)',
  \ '      suffix = name',
  \ '      while (middle != "") {',
  \ '        last = middle',
  \ '        sub(/^.*\//, "", last)',
  \ '        candidate = last "/" suffix',
  \ '        if (length(root "/.../" candidate) > max) break',
  \ '        suffix = candidate',
  \ '        if (middle == last) middle = ""',
  \ '        else sub(/\/[^\/]*$/, "", middle)',
  \ '      }',
  \ '      smart = root "/.../" suffix',
  \ '    }',
  \ '    smart_dir = smart',
  \ '    smart_name = smart',
  \ '    sub(/^.*\//, "", smart_name)',
  \ '    if (smart_dir == smart_name) smart_dir = ""',
  \ '    else sub(/[^\/]*$/, "", smart_dir)',
  \ '    display = sprintf("%s%s%s  %s%s%s%s%s%s", blue, icon, reset, dim, smart_dir, reset, fg, smart_name, reset)',
  \ '    print display "\t" path',
  \ '  }',
  \ "  '",
  \ '}',
  \ '',
  \ 'list_files() {',
  \ '  if ! command -v rg >/dev/null 2>&1; then',
  \ '    find . -type f ! -path "*/.git/*" ! -name ".gitignore" | sed "s#^\./##" | format_files',
  \ '    return',
  \ '  fi',
  \ '',
  \ '  set -- rg --files --hidden --ignore --ignore-vcs --no-require-git --no-messages --glob "!.git" --glob "!.git/*" --glob "!.gitignore"',
  \ '',
  \ '  while IFS= read -r glob; do',
  \ '    [ -n "$glob" ] || continue',
  \ '    glob=$(normalize_glob "$glob")',
  \ '    [ -n "$glob" ] && set -- "$@" --glob "$glob"',
  \ '  done <<EOF',
  \ '$(split_patterns "$(read_file "$include_file")")',
  \ 'EOF',
  \ '',
  \ '  while IFS= read -r glob; do',
  \ '    [ -n "$glob" ] || continue',
  \ '    case "$glob" in',
  \ '      !*) glob=${glob#!} ;;',
  \ '    esac',
  \ '    glob=$(normalize_glob "$glob")',
  \ '    [ -n "$glob" ] && set -- "$@" --glob "!$glob"',
  \ '  done <<EOF',
  \ '$(split_patterns "$(read_file "$exclude_file")")',
  \ 'EOF',
  \ '',
  \ '  "$@" | format_files',
  \ '}',
  \ '',
  \ 'header() {',
  \ '  include=$(read_file "$include_file")',
  \ '  exclude=$(read_file "$exclude_file")',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > ") printf "%s\n" "Include filter: type rg glob/path, Enter applies, Esc cancels, Ctrl-r resets" ;;',
  \ '    "Exclude > ") printf "%s\n" "Exclude filter: type rg glob/path, Enter applies, Esc cancels, Ctrl-r resets" ;;',
  \ '    *) printf "%s\n" "Smart path display, filename + path in preview | Ctrl-o include | Ctrl-e exclude | Ctrl-r reset filters" ;;',
  \ '  esac',
  \ '  if ! command -v rg >/dev/null 2>&1; then',
  \ '    printf "%s\n" "rg unavailable: using find fallback; include/exclude filters require rg"',
  \ '  fi',
  \ '  [ -n "$include" ] && printf "include: %s\n" "$include"',
  \ '  [ -n "$exclude" ] && printf "exclude: %s\n" "$exclude"',
  \ '}',
  \ '',
  \ 'search_actions() {',
  \ '  printf "%s\n" "change-prompt(Files > )+enable-search+transform-query(cat \"$search_file\")+reload(\"$script_file\" files)+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'edit_include_actions() {',
  \ '  printf "%s\n" "disable-search+change-prompt(Include > )+transform-query(cat \"$include_file\")+reload(printf \"\")+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'edit_exclude_actions() {',
  \ '  printf "%s\n" "disable-search+change-prompt(Exclude > )+transform-query(cat \"$exclude_file\")+reload(printf \"\")+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'enter_include() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Files > ") write_current_query "$search_file" ;;',
  \ '    "Exclude > ") write_current_query "$exclude_file" ;;',
  \ '  esac',
  \ '  edit_include_actions',
  \ '}',
  \ '',
  \ 'enter_exclude() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Files > ") write_current_query "$search_file" ;;',
  \ '    "Include > ") write_current_query "$include_file" ;;',
  \ '  esac',
  \ '  edit_exclude_actions',
  \ '}',
  \ '',
  \ 'apply_or_accept() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > ") write_current_query "$include_file"; search_actions ;;',
  \ '    "Exclude > ") write_current_query "$exclude_file"; search_actions ;;',
  \ '    *) printf "%s\n" "accept" ;;',
  \ '  esac',
  \ '}',
  \ '',
  \ 'cancel_or_abort() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > "|"Exclude > ") search_actions ;;',
  \ '    *) printf "%s\n" "abort" ;;',
  \ '  esac',
  \ '}',
  \ '',
  \ 'reset_filters() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Files > ") write_current_query "$search_file" ;;',
  \ '  esac',
  \ '  : > "$include_file"',
  \ '  : > "$exclude_file"',
  \ '  search_actions',
  \ '}',
  \ '',
  \ 'case "$1" in',
  \ '  files) list_files ;;',
  \ '  header) header ;;',
  \ '  ctrl-o) enter_include ;;',
  \ '  ctrl-e) enter_exclude ;;',
  \ '  ctrl-r) reset_filters ;;',
  \ '  enter) apply_or_accept ;;',
  \ '  esc) cancel_or_abort ;;',
  \ 'esac',
  \ ]
endfunction

function! s:fzf_file_accept(file) abort
  let l:parts = split(a:file, "\t", 1)
  let l:file = len(l:parts) > 1 ? l:parts[1] : a:file
  call s:open_file_from_fzf(l:file)
endfunction

function! s:open_file_from_fzf(file) abort
  if empty(a:file)
    return
  endif

  execute 'edit ' . fnameescape(a:file)
  call s:reveal_path_in_nerdtree_soon(expand('%:p'), win_getid())
  call s:refresh_minimap_soon()
endfunction

command! -bang -nargs=* FZFRg
  \ call s:fzf_rg(<q-args>, <bang>0)
command! -bang FZFRgPrompt
  \ call s:fzf_rg_prompt(<bang>0)
command! -bang FZFRgCurrentFile
  \ call s:fzf_rg_current_file_prompt(<bang>0)

function! s:fzf_rg_prompt(bang) abort
  call s:fzf_rg('', a:bang, '', '')
endfunction

function! s:fzf_rg_current_file_prompt(bang) abort
  let l:file = expand('%:p')
  if empty(l:file) || !filereadable(l:file)
    echohl WarningMsg
    echo 'No readable file for current buffer'
    echohl None
    return
  endif

  let l:format = tempname()
  call writefile(s:fzf_rg_current_file_format_script(), l:format)
  call s:fzf_begin()

  try
    call fzf#run(s:fzf_wrap_with_layout('current-file-rg', {
    \   'source': 'printf ""',
    \   'sink*': function('s:fzf_rg_accept', [a:bang]),
    \   'options': s:fzf_rg_current_file_options(l:file, l:format),
    \   'dir': getcwd()
    \ }, a:bang))
  catch
    call s:fzf_release_soon()
    throw v:exception
  endtry
endfunction

function! s:fzf_rg(query, bang, ...) abort
  let l:include = get(a:000, 0, '')
  let l:exclude = get(a:000, 1, '')
  let l:state = s:fzf_rg_state(a:query, l:include, l:exclude)
  let l:action = executable('rg') ? 'rg' : 'grep'
  let l:source = empty(a:query) ? 'printf ""' : s:fzf_rg_state_command(l:state, l:action, shellescape(a:query))
  call s:fzf_begin()

  try
    call fzf#run(s:fzf_wrap_with_layout('rg', {
    \   'source': l:source,
    \   'sink*': function('s:fzf_rg_accept', [a:bang]),
    \   'options': s:fzf_rg_options(a:query, l:include, l:exclude, l:state),
    \   'dir': getcwd()
    \ }, a:bang))
  catch
    call s:fzf_release_soon()
    throw v:exception
  endtry
endfunction

function! s:fzf_begin() abort
  let s:fzf_active_id = get(s:, 'fzf_active_id', 0) + 1
  let g:cadence_fzf_active = s:fzf_active_id
endfunction

function! s:fzf_release_soon() abort
  let l:active_id = get(g:, 'cadence_fzf_active', 0)
  call timer_start(500, { -> s:fzf_release_if_current(l:active_id) })
endfunction

function! s:fzf_release_if_current(active_id) abort
  if get(g:, 'cadence_fzf_active', 0) ==# a:active_id
    let g:cadence_fzf_active = 0
  endif
endfunction

function! s:fzf_rg_state(query, include, exclude) abort
  let l:dir = tempname()
  call mkdir(l:dir, 'p')

  let l:state = {
  \ 'dir': l:dir,
  \ 'script': l:dir . '/fzf-rg-state.sh',
  \ 'format': l:dir . '/format.awk',
  \ 'search': l:dir . '/search',
  \ 'include': l:dir . '/include',
  \ 'exclude': l:dir . '/exclude'
  \ }

  call writefile([a:query], l:state.search)
  call writefile([a:include], l:state.include)
  call writefile([a:exclude], l:state.exclude)
  call writefile(s:fzf_rg_format_script(), l:state.format)
  call writefile(s:fzf_rg_state_script(l:state), l:state.script)
  call setfperm(l:state.script, 'rwx------')

  return l:state
endfunction

function! s:fzf_rg_state_command(state, action, ...) abort
  let l:command = shellescape(a:state.script) . ' ' . shellescape(a:action)
  if a:0 > 0
    let l:command .= ' ' . a:1
  endif
  return l:command
endfunction

function! s:fzf_rg_state_script(state) abort
  return [
  \ '#!/bin/sh',
  \ 'search_file=' . shellescape(a:state.search),
  \ 'include_file=' . shellescape(a:state.include),
  \ 'exclude_file=' . shellescape(a:state.exclude),
  \ 'format_file=' . shellescape(a:state.format),
  \ 'script_file="$0"',
  \ '',
  \ 'read_file() {',
  \ '  [ -f "$1" ] && cat "$1"',
  \ '}',
  \ '',
  \ 'write_current_query() {',
  \ '  printf "%s" "$FZF_QUERY" > "$1"',
  \ '}',
  \ '',
  \ 'split_patterns() {',
  \ "  awk -v input=\"$1\" '",
  \ '  function trim(x) { sub(/^[[:space:]]+/, "", x); sub(/[[:space:]]+$/, "", x); return x }',
  \ '  BEGIN {',
  \ '    depth = 0; item = ""',
  \ '    for (i = 1; i <= length(input); i++) {',
  \ '      c = substr(input, i, 1)',
  \ '      if (c == "{") depth++',
  \ '      else if (c == "}" && depth > 0) depth--',
  \ '      if (c == "," && depth == 0) {',
  \ '        item = trim(item)',
  \ '        if (item != "") print item',
  \ '        item = ""',
  \ '      } else {',
  \ '        item = item c',
  \ '      }',
  \ '    }',
  \ '    item = trim(item)',
  \ '    if (item != "") print item',
  \ '  }',
  \ "  '",
  \ '}',
  \ '',
  \ 'normalize_glob() {',
  \ '  g="$1"',
  \ '  [ -n "$g" ] || return',
  \ '  case "$g" in',
  \ '    */) printf "%s\n" "${g}**"; return ;;',
  \ '  esac',
  \ '  if printf "%s" "$g" | grep -q ''[][?*{}]''; then',
  \ '    printf "%s\n" "$g"',
  \ '    return',
  \ '  fi',
  \ '  if [ -d "$g" ]; then',
  \ '    printf "%s\n" "$g/**"',
  \ '  else',
  \ '    printf "%s\n" "$g"',
  \ '  fi',
  \ '}',
  \ '',
  \ 'run_rg() {',
  \ '  query="$1"',
  \ '  set -- rg --with-filename --column --line-number --no-heading --color=always --colors path:fg:171,178,191 --colors line:fg:99,109,131 --colors column:fg:86,182,194 --colors match:fg:224,108,117 --colors match:style:bold --smart-case --hidden --ignore --ignore-vcs --no-require-git --no-messages --glob "!.git" --glob "!.git/*" --glob "!.gitignore"',
  \ '',
  \ '  while IFS= read -r glob; do',
  \ '    [ -n "$glob" ] || continue',
  \ '    glob=$(normalize_glob "$glob")',
  \ '    [ -n "$glob" ] && set -- "$@" --glob "$glob"',
  \ '  done <<EOF',
  \ '$(split_patterns "$(read_file "$include_file")")',
  \ 'EOF',
  \ '',
  \ '  while IFS= read -r glob; do',
  \ '    [ -n "$glob" ] || continue',
  \ '    case "$glob" in',
  \ '      !*) glob=${glob#!} ;;',
  \ '    esac',
  \ '    glob=$(normalize_glob "$glob")',
  \ '    [ -n "$glob" ] && set -- "$@" --glob "!$glob"',
  \ '  done <<EOF',
  \ '$(split_patterns "$(read_file "$exclude_file")")',
  \ 'EOF',
  \ '',
  \ '  "$@" -- "$query" | awk -F: -f "$format_file"',
  \ '}',
  \ '',
  \ 'run_grep() {',
  \ '  query="$1"',
  \ '  [ -n "$query" ] || return',
  \ '  find . -type f ! -path "*/.git/*" ! -name ".gitignore" -exec grep -IHn -- "$query" {} + 2>/dev/null | awk -F: ''{ file = $1; line = $2; text = $0; sub(/^[^:]*:[^:]*:/, "", text); sub(/^\.\//, "", file); print file ":" line ":1:" text }'' | awk -F: -f "$format_file"',
  \ '}',
  \ '',
  \ 'header() {',
  \ '  include=$(read_file "$include_file")',
  \ '  exclude=$(read_file "$exclude_file")',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > ") printf "%s\n" "Include filter: type rg glob/path, Enter applies, Esc cancels, Ctrl-r resets" ;;',
  \ '    "Exclude > ") printf "%s\n" "Exclude filter: type rg glob/path, Enter applies, Esc cancels, Ctrl-r resets" ;;',
  \ '    *) printf "%s\n" "Ctrl-o include | Ctrl-e exclude | Ctrl-r reset filters" ;;',
  \ '  esac',
  \ '  if ! command -v rg >/dev/null 2>&1; then',
  \ '    printf "%s\n" "rg unavailable: using grep fallback; include/exclude filters require rg"',
  \ '  fi',
  \ '  [ -n "$include" ] && printf "include: %s\n" "$include"',
  \ '  [ -n "$exclude" ] && printf "exclude: %s\n" "$exclude"',
  \ '}',
  \ '',
  \ 'search_actions() {',
  \ '  printf "%s\n" "change-prompt(Search > )+disable-search+rebind(change)+transform-query(cat \"$search_file\")+reload(\"$script_file\" rg-file)+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'edit_include_actions() {',
  \ '  printf "%s\n" "unbind(change)+change-prompt(Include > )+transform-query(cat \"$include_file\")+reload(printf \"\")+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'edit_exclude_actions() {',
  \ '  printf "%s\n" "unbind(change)+change-prompt(Exclude > )+transform-query(cat \"$exclude_file\")+reload(printf \"\")+transform-header(\"$script_file\" header)"',
  \ '}',
  \ '',
  \ 'enter_include() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Search > ") write_current_query "$search_file" ;;',
  \ '    "Exclude > ") write_current_query "$exclude_file" ;;',
  \ '  esac',
  \ '  edit_include_actions',
  \ '}',
  \ '',
  \ 'enter_exclude() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Search > ") write_current_query "$search_file" ;;',
  \ '    "Include > ") write_current_query "$include_file" ;;',
  \ '  esac',
  \ '  edit_exclude_actions',
  \ '}',
  \ '',
  \ 'apply_or_accept() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > ") write_current_query "$include_file"; search_actions ;;',
  \ '    "Exclude > ") write_current_query "$exclude_file"; search_actions ;;',
  \ '    *) printf "%s\n" "accept" ;;',
  \ '  esac',
  \ '}',
  \ '',
  \ 'cancel_or_abort() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Include > "|"Exclude > ") search_actions ;;',
  \ '    *) printf "%s\n" "abort" ;;',
  \ '  esac',
  \ '}',
  \ '',
  \ 'reset_filters() {',
  \ '  case "$FZF_PROMPT" in',
  \ '    "Search > ") write_current_query "$search_file" ;;',
  \ '  esac',
  \ '  : > "$include_file"',
  \ '  : > "$exclude_file"',
  \ '  search_actions',
  \ '}',
  \ '',
  \ 'case "$1" in',
  \ '  rg) run_rg "$2" ;;',
  \ '  grep) run_grep "$2" ;;',
  \ '  rg-file) run_rg "$(read_file "$search_file")" ;;',
  \ '  grep-file) run_grep "$(read_file "$search_file")" ;;',
  \ '  header) header ;;',
  \ '  ctrl-o) enter_include ;;',
  \ '  ctrl-e) enter_exclude ;;',
  \ '  ctrl-r) reset_filters ;;',
  \ '  enter) apply_or_accept ;;',
  \ '  esc) cancel_or_abort ;;',
  \ 'esac',
  \ ]
endfunction

function! s:fzf_rg_state_reload_command(state) abort
  let l:action = executable('rg') ? 'rg' : 'grep'
  return 'test -n {q} && ' . s:fzf_rg_state_command(a:state, l:action, '{q}') . ' || true'
endfunction

function! s:fzf_rg_current_file_reload_command(file, format) abort
  if executable('rg')
    let l:command = 'rg --with-filename --column --line-number --no-heading --color=always --colors ''path:fg:171,178,191'' --colors ''line:fg:99,109,131'' --colors ''column:fg:86,182,194'' --colors ''match:fg:224,108,117'' --colors ''match:style:bold'' --smart-case --no-messages'
    return 'test -n {q} && ' . l:command . ' -- {q} ' . shellescape(a:file) . ' | awk -F: -f ' . shellescape(a:format) . ' || true'
  endif

  return 'test -n {q} && grep -Hn -- {q} ' . shellescape(a:file) . ' 2>/dev/null | awk -F: ''{ file = $1; line = $2; text = $0; sub(/^[^:]*:[^:]*:/, "", text); print file ":" line ":1:" text }'' | awk -F: -f ' . shellescape(a:format) . ' || true'
endfunction

function! s:fzf_rg_accept(bang, lines) abort
  if len(a:lines) < 2
    call s:fzf_release_soon()
    return
  endif

  let l:query = a:lines[0]
  let l:key = a:lines[1]
  let l:matches = a:lines[2:]

  call s:open_rg_results([l:key] + l:matches)
  call s:fzf_release_soon()
endfunction

