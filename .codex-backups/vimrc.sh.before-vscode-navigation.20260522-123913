function! s:parse_rg_result(line) abort
  let l:parts = split(a:line, "\t", 1)
  if len(l:parts) < 4
    return {}
  endif

  return {
  \ 'filename': l:parts[1],
  \ 'lnum': str2nr(l:parts[2]),
  \ 'col': str2nr(l:parts[3]),
  \ 'text': len(l:parts) > 4 ? join(l:parts[4:], "\t") : ''
  \ }
endfunction

function! s:open_rg_results(lines) abort
  if empty(a:lines)
    return
  endif

  let l:expected_keys = ['ctrl-q', 'ctrl-v', 'ctrl-x', 'ctrl-t']
  let l:first_line = a:lines[0]
  let l:key = index(l:expected_keys, l:first_line) >= 0 ? l:first_line : ''
  let l:matches = empty(l:key) ? a:lines : a:lines[1:]
  if empty(l:first_line)
    let l:matches = a:lines[1:]
  endif
  if empty(l:matches)
    return
  endif

  if l:key ==# 'ctrl-q'
    call s:send_rg_results_to_quickfix(l:matches)
    return
  endif

  let l:command = get({
  \ 'ctrl-v': 'vsplit',
  \ 'ctrl-x': 'split',
  \ 'ctrl-t': 'tabedit'
  \ }, l:key, 'edit')

  call s:open_rg_result(l:matches[0], l:command)
endfunction

function! s:send_rg_results_to_quickfix(lines) abort
  let l:items = []
  for l:line in a:lines
    let l:match = s:parse_rg_result(l:line)
    if !empty(l:match)
      call add(l:items, {
      \ 'filename': l:match.filename,
      \ 'lnum': l:match.lnum,
      \ 'col': l:match.col,
      \ 'text': l:match.text
      \ })
    endif
  endfor

  if !empty(l:items)
    call setqflist(l:items, 'r')
    copen
    cc
  endif
endfunction

function! s:open_rg_result(line, ...) abort
  let l:match = s:parse_rg_result(a:line)
  if empty(l:match)
    return
  endif

  let l:command = get(a:000, 0, 'edit')
  execute l:command . ' +' . l:match.lnum . ' ' . fnameescape(l:match.filename)
  call cursor(l:match.lnum, max([l:match.col, 1]))
  normal! zvzz
  call s:reveal_path_in_nerdtree_soon(expand('%:p'), win_getid())
  call s:refresh_minimap_soon()
endfunction


