    \ 'filter': function('s:command_palette_filter'),
    \ 'callback': function('s:run_command_palette_entry'),
    \ 'zindex': 310
    \ })
    return
  endif

  let l:choice = inputlist(['Command Palette'] + l:lines)
  call s:run_command_palette_entry(0, l:choice)
endfunction

function! s:show_hotkeys() abort
  let l:lines = s:hotkey_lines()
  if exists('*popup_create')
    let l:width = min([104, max([72, &columns - 8])])
    let l:height = min([len(l:lines), max([1, &lines - 4])])
    let l:line = max([1, float2nr((&lines - l:height) / 2)])
    let l:col = max([1, float2nr((&columns - l:width) / 2)])

    call popup_create(l:lines, {
    \ 'title': ' Hotkeys ',
    \ 'line': l:line,
    \ 'col': l:col,
    \ 'minwidth': l:width,
    \ 'maxwidth': l:width,
    \ 'maxheight': l:height,
    \ 'padding': [0, 1, 0, 1],
    \ 'border': [],
    \ 'highlight': 'Pmenu',
    \ 'borderhighlight': repeat(['PmenuSel'], 8),
    \ 'filter': function('s:hotkeys_popup_filter'),
    \ 'mapping': 0,
    \ 'zindex': 300
    \ })
    return
  endif

  botright new
  setlocal buftype=nofile bufhidden=wipe nobuflisted noswapfile modifiable
  call setline(1, l:lines)
  setlocal nomodifiable
  nnoremap <silent><buffer> q :bd!<CR>
  nnoremap <silent><buffer> <Esc> :bd!<CR>
endfunction

