function! s:start_current_file_search() abort
  call feedkeys('/', 'n')
endfunction

if get(g:, 'cadence_has_coc', 0)
  function! s:coc_add_command(id, command, title) abort
    if !exists('g:coc_vim_commands')
      let g:coc_vim_commands = []
    endif
    let l:config = {'id': a:id, 'cmd': a:command, 'title': a:title}
    call filter(g:coc_vim_commands, 'get(v:val, "id", "") !=# a:id')
    try
      call coc#add_command(a:id, a:command, a:title)
    catch
      call filter(g:coc_vim_commands, 'get(v:val, "id", "") !=# a:id')
      call add(g:coc_vim_commands, l:config)
    endtry
  endfunction

  call s:coc_add_command('vim.commandPalette', 'CommandPalette', 'Command palette (<C-p>)')
  call s:coc_add_command('vim.hotkeys', 'VimHotkeys', 'Show Vim hotkeys (:help, :hotkeys)')
